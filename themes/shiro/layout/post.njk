{% extends "_layout.njk" %}

{% block content %}
{% set article_show_meta = true %}
{% set article_extra %}
    <!-- Post Navigation: Hexo's page.prev = newer post, page.next = older post -->
    <div class="section-divider flex justify-between items-center text-sm md:text-base">
        {% if page.prev %}
        <a href="{{ url_for(page.prev.path) }}" class="post-nav-link group text-left" title="{{ page.prev.title }}">
             <span aria-hidden="true">&larr;</span>
             <span class="post-nav-title">{{ page.prev.title }}</span>
        </a>
        {% else %}
        <div></div>
        {% endif %}

        {% if page.next %}
        <a href="{{ url_for(page.next.path) }}" class="post-nav-link group text-right" title="{{ page.next.title }}">
            <span class="post-nav-title">{{ page.next.title }}</span>
            <span aria-hidden="true">&rarr;</span>
        </a>
        {% else %}
        <div></div>
        {% endif %}
    </div>
{% endset %}
{% include "_partial/components/article.njk" %}
{% endblock %}
