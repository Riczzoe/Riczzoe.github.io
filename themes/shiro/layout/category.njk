{% extends "_layout.njk" %}
{% from "_macro/ui.njk" import divider, icon_folder with context %}
{% from "_macro/archive.njk" import render_list, render_simple_list with context %}

{% block content %}
<section class="section-shell">
    <header class="section-header">
        <h1 class="section-title">
            {% if is_category() and page.category %}
            {{ __('nav.categories') }}: {{ page.category }}
            {% else %}
            {{ __('nav.categories') }}
            {% endif %}
        </h1>
        {{ divider() }}
    </header>

    {% if is_category() %}
        {% set cat = site.categories.findOne({name: page.category}) %}
        {% if cat and cat.posts.length > 0 %}
            {{ render_list(cat.posts.sort('date', -1)) }}
        {% else %}
            {% include "_partial/common/empty.njk" %}
        {% endif %}
    {% else %}
        {% if site.categories.length > 0 %}
            <div class="space-y-16 max-w-2xl mx-auto">
                {% for cat in site.categories.toArray() | sort(false, false, "name") %}
                <div id="cat-{{ cat.slug }}" class="scroll-mt-24">
                    <h2 class="section-heading">
                        {{ icon_folder() }}
                        {{ cat.name }}
                    </h2>
                    {{ render_simple_list(cat.posts.sort('date', -1)) }}
                </div>
                {% endfor %}
            </div>
        {% else %}
            {% include "_partial/common/empty.njk" %}
        {% endif %}
    {% endif %}
</section>
{% endblock %}
