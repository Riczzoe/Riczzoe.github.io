{% from "_macro/ui.njk" import seal, icon_rss, icon_chevron_down, icon_theme_system, icon_theme_light, icon_theme_dark with context %}
<header class="relative">

    <div class="relative flex items-start justify-center">
        <div class="text-center">
            <div class="relative inline-block">
                {% if is_home() %}
                <h1 class="site-title">
                    <a href="{{ url_for('/') }}">{{ config.title | default("白夜書簡", true) }}</a>
                </h1>
                {% else %}
                <p class="site-title">
                    <a href="{{ url_for('/') }}">{{ config.title | default("白夜書簡", true) }}</a>
                </p>
                {% endif %}
                <!-- Seal: Mathematically Centered -->
                {% if theme.site.seal %}
                <div
                    class="absolute left-full top-1/2 -translate-y-1/2 ml-1 sm:ml-4 origin-left scale-75 sm:scale-110">
                    {{ seal(theme.site.seal_text | default("白", true)) }}
                </div>
                {% endif %}
            </div>
            {% if config.subtitle %}
            <p class="site-subtitle">
                {{ config.subtitle }}
            </p>
            {% endif %}
            <div class="mt-3 sm:mt-4 flex justify-center gap-2">
                {% if theme.site.rss.enabled %}
                <a class="group header-pill-btn"
                    href="{{ url_for(theme.site.rss.path | default('/atom.xml')) }}" target="_blank">
                    {{ icon_rss() }}
                    <span>RSS</span>
                </a>
                {% endif %}
                {% if theme.dark_mode.toggle != false %}
                {% set dm_default = theme.dark_mode.default | default("system", true) %}
                <button id="themeToggle" class="group header-pill-btn" aria-label="{{ __('theme.' + dm_default) }}" data-label-system="{{ __('theme.system') }}" data-label-light="{{ __('theme.light') }}" data-label-dark="{{ __('theme.dark') }}">
                    {{ icon_theme_system() }}
                    {{ icon_theme_light() }}
                    {{ icon_theme_dark() }}
                </button>
                {% endif %}
            </div>
        </div>
    </div>
</header>

<!-- Navigation -->
<nav class="mt-8 md:mt-10" aria-label="{{ __('nav.menu') }}">
    <!-- Mobile Toggle -->
    <div class="flex items-center justify-center md:hidden">
        <button id="menuBtn"
            class="focus-elegant inline-flex items-center gap-2 rounded-full border border-slate-200 bg-paper/95 px-4 py-2 text-sm text-slate-700 shadow-xs"
            aria-expanded="false" aria-controls="mobileMenu">
            <span class="text-base leading-none tracking-widest">{{ __('nav.menu') }}</span>
            {{ icon_chevron_down(id="menuChevron") }}
        </button>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden md:block">
        <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-base text-slate-700 px-4">
            {% for item in theme.menu %}
            <li><a class="focus-elegant rounded-md px-2 py-1 hover:text-seal transition-colors"
                    href="{{ url_for(item.url) }}" {% if item.target %}target="{{ item.target }}"{% endif %}>{{ item.name }}</a></li>
            {% if not loop.last %}
            <li class="nav-divider text-slate-400 select-none" role="separator" aria-hidden="true">/</li>
            {% endif %}
            {% endfor %}
        </ul>
    </div>

    <!-- Mobile Menu Panel -->
    <div id="mobileMenu" class="menu-panel md:hidden mt-4" data-open="false">
        <ul
            class="mx-auto max-w-sm max-h-menu overflow-y-auto rounded-2xl border border-slate-200 bg-paper/95 shadow-xs">
            {% for item in theme.menu %}
            <li><a class="focus-elegant block px-6 py-3 text-center text-slate-800 hover:text-seal hover:bg-seal/5 transition-colors"
                    href="{{ url_for(item.url) }}" {% if item.target %}target="{{ item.target }}"{% endif %}>{{ item.name }}</a></li>
            {% if not loop.last %}
            <li class="h-px bg-slate-200/70" role="separator" aria-hidden="true"></li>
            {% endif %}
            {% endfor %}
        </ul>
    </div>
</nav>
