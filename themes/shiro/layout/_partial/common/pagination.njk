{% if page.total > 1 %}
<section class="mt-8 md:mt-10" aria-label="{{ __('page.pagination') }}">
    <nav class="pagination flex flex-wrap items-center justify-center gap-6 sm:gap-8 text-sm md:text-base font-medium">
        {{ paginator({
            prev_text: __('page.prev'),
            next_text: __('page.next'),
            mid_size: 1,
            space: '&hellip;',
            show_all: false
        }) }}
    </nav>
</section>
{% endif %}
