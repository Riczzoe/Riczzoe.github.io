{% if theme.comments.enabled and theme.comments.provider == "giscus" and theme.comments.giscus.repo %}
<div id="giscus-container" class="giscus"></div>
<script>
(function() {
    const s = document.createElement('script');
    s.src = {{ (theme.comments.giscus.src or 'https://giscus.app/client.js') | dump | safe }};
    s.async = true;
    s.crossOrigin = 'anonymous';
    const attrs = {
        'data-repo': {{ theme.comments.giscus.repo | dump | safe }},
        'data-repo-id': {{ theme.comments.giscus.repo_id | dump | safe }},
        'data-category': {{ theme.comments.giscus.category | dump | safe }},
        'data-category-id': {{ theme.comments.giscus.category_id | dump | safe }},
        'data-mapping': {{ (theme.comments.giscus.mapping or 'pathname') | dump | safe }},
        'data-strict': {{ (theme.comments.giscus.strict or '0') | dump | safe }},
        'data-reactions-enabled': {{ (theme.comments.giscus.reactions_enabled or '1') | dump | safe }},
        'data-emit-metadata': {{ (theme.comments.giscus.emit_metadata or '0') | dump | safe }},
        'data-input-position': {{ (theme.comments.giscus.input_position or 'bottom') | dump | safe }},
        {# Fallback to giscus built-in 'preferred_color_scheme' theme if user removes the theme config #}
        'data-theme': {{ (theme.comments.giscus.theme or 'preferred_color_scheme') | dump | safe }},
        'data-lang': {{ (theme.comments.giscus.lang or 'en') | dump | safe }},
        {%- if theme.comments.giscus.lazy_loading %}
        'data-loading': 'lazy',
        {%- endif %}
    };
    for (const [key, value] of Object.entries(attrs)) {
        s.setAttribute(key, value);
    }
    const container = document.getElementById('giscus-container');
    if (container) {
        container.appendChild(s);
    }
})();
</script>
{% endif %}
