{% if theme.analytics.google.enabled and theme.analytics.google.id %}
  <!-- Google tag (gtag.js) — SRI omitted because Google updates this script frequently,
       which would break integrity checks. Use CSP script-src instead for protection. -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ theme.analytics.google.id }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', {{ theme.analytics.google.id | dump | safe }});
  </script>
{% endif %}
