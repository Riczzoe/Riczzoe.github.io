{% from "_macro/ui.njk" import icon_chevron_down with context %}
<!-- Inline TOC (small screens < xl) -->
<div id="tocInline" class="toc-inline xl:hidden mb-8">
    <button class="toc-toggle" aria-expanded="false" aria-controls="tocInlineBody">
        <span class="toc-toggle-title">{{ __('toc.title') }}</span>
        {{ icon_chevron_down("toc-chevron size-4") }}
    </button>
    <div class="toc-body" id="tocInlineBody" data-open="false"></div>
</div>

<!-- Sidebar TOC (xl+ screens) -->
<aside id="tocSidebar" class="toc-sidebar hidden xl:block" aria-label="{{ __('toc.title') }}">
    <div class="toc-sidebar-inner">
        <p class="toc-sidebar-title">{{ __('toc.title') }}</p>
        <div class="toc-body"></div>
    </div>
</aside>
